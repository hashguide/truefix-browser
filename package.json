{
  "name": "@price-scraper/service",
  "version": "1.0.0",
  "description": "AI-driven adaptive scraping engine for automotive parts and labor data",
  "author": "Price Scraper Team",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "db:migrate": "tsx src/storage/migrations/runner.ts",
    "db:seed": "tsx src/storage/migrations/seed.ts",
    "lint": "eslint src tests --ext .ts",
    "format": "prettier --write src tests",
    "type-check": "tsc --noEmit",
    "docker:build": "docker-compose -f docker-compose.yml build",
    "docker:up": "docker-compose -f docker-compose.yml up -d",
    "docker:down": "docker-compose -f docker-compose.yml down",
    "docker:logs": "docker-compose -f docker-compose.yml logs -f"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^11.1.0",
    "@fastify/jwt": "^9.0.3",
    "@fastify/rate-limit": "^10.3.0",
    "axios": "^1.14.0",
    "bullmq": "^5.71.1",
    "dotenv": "^17.3.1",
    "fastify": "^4.25.2",
    "fastify-sse-v2": "^4.2.2",
    "jsonwebtoken": "^9.0.3",
    "knex": "^3.2.7",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "playwright": "^1.58.2",
    "redis": "^4.7.1",
    "uuid": "^13.0.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@faker-js/faker": "^10.4.0",
    "@types/node": "^25.5.0",
    "@types/pg": "^8.20.0",
    "@types/uuid": "^11.0.0",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "@vitest/coverage-v8": "^4.1.2",
    "eslint": "^10.1.0",
    "prettier": "^3.1.1",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0",
    "typescript": "^5.3.3",
    "vitest": "^4.1.2"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
